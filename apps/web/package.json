{
  "name": "@app/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx ../../packages/infisical-runner/src/cli.ts web dev -- vite dev",
    "dev:web": "pnpm run dev",
    "build": "tsx ../../packages/infisical-runner/src/cli.ts web build -- vite build",
    "build:ci": "vite build",
    "start": "vite preview",
    "start:ci": "node .output/server/index.mjs",
    "check": "biome check .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx ../../packages/infisical-runner/src/cli.ts web test -- vitest run --passWithNoTests",
    "test:ci": "vitest run --passWithNoTests",
    "test:watch": "tsx ../../packages/infisical-runner/src/cli.ts web test:watch -- vitest --passWithNoTests",
    "test:watch:no-infisical": "vitest --passWithNoTests"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@clerk/tanstack-react-start": "^1.4.13",
    "@clerk/ui": "^1.24.2",
    "@package/feature-flags": "workspace:*",
    "@package/logger": "workspace:*",
    "@package/services": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-router": "latest",
    "@tanstack/react-start": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "nitro": "3.0.260610-beta",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tslib": "^2.8.1",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@package/eslint": "workspace:*",
    "@package/tsconfig": "workspace:*",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^6.0.3",
    "vite": "latest"
  }
}
