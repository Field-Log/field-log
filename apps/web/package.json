{
  "name": "@repo/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx ../../packages/infisical-runner/src/cli.ts web dev -- vite dev",
    "dev:web": "pnpm run dev",
    "build": "vite build",
    "start": "vite preview --outDir dist/client",
    "check": "biome check .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx ../../packages/infisical-runner/src/cli.ts web test -- vitest run --passWithNoTests",
    "test:ci": "vitest run --passWithNoTests",
    "test:watch": "tsx ../../packages/infisical-runner/src/cli.ts web test:watch -- vitest --passWithNoTests",
    "test:watch:no-infisical": "vitest --passWithNoTests"
  },
  "dependencies": {
    "@tanstack/react-router": "latest",
    "@tanstack/react-start": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@repo/eslint": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "vite": "latest"
  }
}
