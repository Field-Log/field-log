{
  "name": "@app/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "tsx ../../packages/infisical-runner/src/cli.ts mobile start -- expo start",
    "dev": "pnpm run start",
    "dev:ios": "pnpm run ios",
    "dev:android": "pnpm run android",
    "android": "tsx ../../packages/infisical-runner/src/cli.ts mobile android -- expo start --android",
    "ios": "tsx ../../packages/infisical-runner/src/cli.ts mobile ios -- expo start --ios",
    "web": "tsx ../../packages/infisical-runner/src/cli.ts mobile web -- expo start --web",
    "build": "expo export --platform all",
    "build:ci": "expo export --platform all",
    "check": "biome check .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx src/env.assert.ts && tsx ../../packages/infisical-runner/src/cli.ts mobile test -- jest --passWithNoTests",
    "test:ci": "tsx src/env.assert.ts && jest --passWithNoTests",
    "test:watch": "tsx src/env.assert.ts && tsx ../../packages/infisical-runner/src/cli.ts mobile test:watch -- jest --watch",
    "test:watch:no-infisical": "tsx src/env.assert.ts && jest --watch"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.11.0",
    "@package/logger": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "expo": "latest",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-crypto": "~15.0.9",
    "expo-file-system": "~19.0.23",
    "expo-image-picker": "~17.0.11",
    "expo-notifications": "~0.32.17",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "latest",
    "expo-task-manager": "~14.0.9",
    "expo-web-browser": "~15.0.11",
    "firebase": "^12.15.0",
    "react": "latest",
    "react-dom": "latest",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-native/jest-preset": "0.85.3",
    "@package/eslint": "workspace:*",
    "@package/tsconfig": "workspace:*",
    "@types/react": "latest",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.14"
  }
}
