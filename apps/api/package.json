{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx ../../packages/infisical-runner/src/cli.ts api dev -- tsx watch src/index.ts",
    "dev:web": "pnpm run dev",
    "dev:ios": "pnpm run dev",
    "dev:android": "pnpm run dev",
    "build": "tsc -p tsconfig.json",
    "build:ci": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "biome check .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx ../../packages/infisical-runner/src/cli.ts api test -- vitest run",
    "test:ci": "vitest run",
    "test:watch": "tsx ../../packages/infisical-runner/src/cli.ts api test:watch -- vitest",
    "test:watch:no-infisical": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "latest",
    "@repo/logger": "workspace:*",
    "@repo/services": "workspace:*",
    "@repo/types": "workspace:*",
    "hono": "latest"
  },
  "devDependencies": {
    "@repo/eslint": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "tsx": "latest"
  }
}
