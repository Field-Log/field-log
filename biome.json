{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.turbo",
      "!**/dist",
      "!**/build",
      "!**/.output",
      "!**/.tanstack",
      "!**/.expo",
      "!**/coverage",
      "!**/routeTree.gen.ts",
      "!apps/autmog/images",
      "!scrapers/**/data"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "overrides": [
    {
      "includes": ["apps/autmog/index.html"],
      "linter": {
        "rules": {
          "complexity": {
            "noImportantStyles": "off"
          },
          "style": {
            "noDescendingSpecificity": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/field-log/**"],
      "linter": {
        "rules": {
          "correctness": {
            "useExhaustiveDependencies": "warn"
          },
          "suspicious": {
            "noArrayIndexKey": "warn"
          }
        }
      }
    },
    {
      "includes": [
        "apps/api/src/**/*.{js,jsx,ts,tsx}",
        "apps/mobile/src/**/*.{js,jsx,ts,tsx}",
        "apps/web/src/**/*.{js,jsx,ts,tsx}",
        "packages/database/src/**/*.{js,jsx,ts,tsx}",
        "packages/services/src/**/*.{js,jsx,ts,tsx}"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "error"
          }
        }
      }
    },
    {
      "includes": ["packages/database/src/**/*.{js,jsx,ts,tsx}"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@package/logger": "Keep packages/database storage-only. Log database behavior from packages/services instead."
                }
              }
            }
          }
        }
      }
    }
  ],
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
