{
  "$schema": "https://v2-10-4.turborepo.dev/schema.json",
  "globalDependencies": [".env", ".env.*"],
  "tasks": {
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "dev:web": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "dev:ios": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "dev:android": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "AXIOM_DATASET",
        "AXIOM_EDGE_DOMAIN",
        "AXIOM_TOKEN",
        "API_PREVIEW_WORKER_HOST",
        "CLERK_PUBLISHABLE_KEY",
        "CLERK_SECRET_KEY",
        "DATABASE_URL",
        "EXPO_PUBLIC_API_URL",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "EXPO_PUBLIC_LOG_PROXY_CLIENT_KEY",
        "LOGGER",
        "LOG_LEVEL",
        "LOG_PROXY_CLIENT_KEY",
        "LOG_PROXY_URL",
        "PORT",
        "SITE_URL",
        "VERCEL_ENV",
        "VERCEL_GIT_PULL_REQUEST_ID",
        "VITE_API_BASE_URL",
        "VITE_CLERK_PUBLISHABLE_KEY",
        "VITE_CLERK_SIGN_IN_URL",
        "VITE_CLERK_SIGN_UP_URL",
        "VITE_LOG_PROXY_CLIENT_KEY",
        "VITE_LOG_PROXY_URL"
      ],
      "outputs": ["dist/**", "build/**", ".output/**", ".vercel/output/**"]
    },
    "build:ci": {
      "dependsOn": ["^build:ci"],
      "env": [
        "AXIOM_DATASET",
        "AXIOM_EDGE_DOMAIN",
        "AXIOM_TOKEN",
        "API_PREVIEW_WORKER_HOST",
        "CLERK_PUBLISHABLE_KEY",
        "CLERK_SECRET_KEY",
        "DATABASE_URL",
        "EXPO_PUBLIC_API_URL",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "EXPO_PUBLIC_LOG_PROXY_CLIENT_KEY",
        "LOGGER",
        "LOG_LEVEL",
        "LOG_PROXY_CLIENT_KEY",
        "LOG_PROXY_URL",
        "PORT",
        "SITE_URL",
        "VERCEL_ENV",
        "VERCEL_GIT_PULL_REQUEST_ID",
        "VITE_API_BASE_URL",
        "VITE_CLERK_PUBLISHABLE_KEY",
        "VITE_CLERK_SIGN_IN_URL",
        "VITE_CLERK_SIGN_UP_URL",
        "VITE_LOG_PROXY_CLIENT_KEY",
        "VITE_LOG_PROXY_URL"
      ],
      "outputs": ["dist/**", "build/**", ".output/**", ".vercel/output/**"]
    },
    "lint": {
      "outputs": []
    },
    "check": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:ci": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:watch:no-infisical": {
      "cache": false,
      "persistent": true
    }
  }
}
