{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @app/scraper... build",
    "watchPatterns": [
      "apps/scraper/**",
      "packages/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "railway.json",
      "turbo.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @app/scraper run cron:run",
    "cronSchedule": "*/15 * * * *",
    "restartPolicyType": "NEVER"
  }
}
