{
  "name": "@package/logger",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:ci": "tsc -p tsconfig.json",
    "check": "biome check .",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "dev:web": "pnpm run dev",
    "dev:ios": "pnpm run dev",
    "dev:android": "pnpm run dev",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:axiom": "tsx ../infisical-runner/src/cli.ts logger test:axiom -- tsx integration/axiom-live.ts",
    "test:ci": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "test:watch:no-infisical": "vitest --passWithNoTests"
  },
  "devDependencies": {
    "@package/eslint": "workspace:*",
    "@package/tsconfig": "workspace:*"
  }
}
