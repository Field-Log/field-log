{
  "name": "@package/github-discord-notifier",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:ci": "tsc -p tsconfig.json",
    "check": "biome check .",
    "lint": "eslint .",
    "notify": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
