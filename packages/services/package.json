{
  "name": "@package/services",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:ci": "tsc -p tsconfig.json",
    "check": "biome check .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --exclude \"dist/**\"",
    "test:ci": "vitest run --passWithNoTests --exclude \"dist/**\"",
    "test:watch": "vitest --passWithNoTests --exclude \"dist/**\"",
    "test:watch:no-infisical": "vitest --passWithNoTests --exclude \"dist/**\""
  },
  "dependencies": {
    "@package/database": "workspace:*",
    "@package/images": "workspace:*",
    "@package/logger": "workspace:*",
    "drizzle-orm": "latest"
  },
  "devDependencies": {
    "@package/eslint": "workspace:*",
    "@package/tsconfig": "workspace:*"
  }
}
