{
  "name": "@package/database",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:ci": "tsc -p tsconfig.json",
    "check": "biome check .",
    "db:check": "drizzle-kit check --config=drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts && pnpm run db:generate:docs",
    "db:generate:docs": "tsx scripts/generate-schema-docs.ts",
    "db:migrate": "tsx ../infisical-runner/src/cli.ts database db:migrate -- drizzle-kit migrate --config=drizzle.config.ts",
    "db:resolve-conflicts": "node scripts/print-resolve-conflicts-prompt.js",
    "db:studio": "tsx ../infisical-runner/src/cli.ts database db:studio -- drizzle-kit studio --config=drizzle.config.ts --host=127.0.0.1 --port=4009",
    "db:view": "concurrently --kill-others --names studio,visualizer,view \"pnpm db:studio\" \"pnpm db:visualizer\" \"wait-on tcp:127.0.0.1:4009 tcp:127.0.0.1:4010 && pnpm db:view:shell\"",
    "db:view:shell": "node ../../scripts/drizzle-view.mjs --studio \"https://local.drizzle.studio?port=4009\" --visualizer http://127.0.0.1:4010 --port 4011",
    "db:visualizer": "drizzle-lab visualizer --config drizzle.config.ts --ts-config tsconfig.json --port=4010",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --exclude \"dist/**\"",
    "test:ci": "vitest run --passWithNoTests --exclude \"dist/**\"",
    "test:watch": "vitest --passWithNoTests --exclude \"dist/**\"",
    "test:watch:no-infisical": "vitest --passWithNoTests --exclude \"dist/**\""
  },
  "dependencies": {
    "@neondatabase/serverless": "latest",
    "@t3-oss/env-core": "^0.13.11",
    "drizzle-orm": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@package/eslint": "workspace:*",
    "@package/tsconfig": "workspace:*",
    "drizzle-kit": "latest"
  }
}
