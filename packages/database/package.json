{
  "name": "@repo/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:ci": "tsc -p tsconfig.json",
    "check": "biome check .",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx ../infisical-runner/src/cli.ts database db:migrate -- drizzle-kit migrate --config=drizzle.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --exclude \"dist/**\"",
    "test:ci": "vitest run --passWithNoTests --exclude \"dist/**\"",
    "test:watch": "vitest --passWithNoTests --exclude \"dist/**\"",
    "test:watch:no-infisical": "vitest --passWithNoTests --exclude \"dist/**\""
  },
  "dependencies": {
    "@neondatabase/serverless": "latest",
    "@t3-oss/env-core": "^0.13.11",
    "drizzle-orm": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/eslint": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "drizzle-kit": "latest"
  }
}
