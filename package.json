{
  "name": "machinedpens.info",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo run dev --filter='./apps/*' --filter=@repo/logger",
    "dev:web": "turbo run dev:web --filter=@repo/api --filter=@repo/web --filter=@repo/logger",
    "dev:expo": "turbo run dev --filter=@repo/mobile --filter=@repo/logger",
    "dev:ios": "turbo run dev:ios --filter=@repo/api --filter=@repo/mobile --filter=@repo/logger",
    "dev:android": "turbo run dev:android --filter=@repo/api --filter=@repo/mobile --filter=@repo/logger",
    "build": "turbo run build",
    "build:ci": "turbo run build:ci",
    "db:generate": "pnpm --filter @repo/database db:generate",
    "db:migrate": "pnpm --filter @repo/database db:migrate",
    "lint": "biome lint . && turbo run lint",
    "format": "biome check --write --linter-enabled=false .",
    "prepare": "git config core.hooksPath .githooks",
    "check": "biome check --write . && turbo run check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "test:logger:axiom": "tsx packages/infisical-runner/src/cli.ts logger test:axiom -- tsx packages/logger/integration/axiom-live.ts",
    "test:watch": "turbo run test:watch",
    "test:watch:no-infisical": "turbo run test:watch:no-infisical"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@eslint/js": "latest",
    "@types/node": "latest",
    "eslint": "latest",
    "tsx": "latest",
    "turbo": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
