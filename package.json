{
  "name": "machinedpens.info",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo run dev --filter='./apps/*'",
    "dev:web": "turbo run dev:web --filter=@repo/api --filter=@repo/web",
    "dev:ios": "turbo run dev:ios --filter=@repo/api --filter=@repo/mobile",
    "dev:android": "turbo run dev:android --filter=@repo/api --filter=@repo/mobile",
    "build": "turbo run build",
    "lint": "biome lint . && turbo run lint",
    "format": "biome format --write .",
    "check": "biome check --write . && turbo run check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@eslint/js": "latest",
    "@types/node": "latest",
    "eslint": "latest",
    "turbo": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
